import math;
import clot.science.physics;

q1 = 4 * pow(10, -6);
q2 = 2 * pow(10, -6);
r = 0.3;

func couele(q1 = 4 * pow(10, -6), q2 = 2 * pow(10, -6), r = 0.3):
    println("Fuerza electrica: ");
    println(coulomb_force(q1, q2, r));
    print(endl);

    println("Campo electrico generado por q1:");
    println(electric_field_point(q1, r));
    print(endl);
endfunc

couele();

